templ Index(site config.Site, year int, list []posts.Post) {
	@Layout(site, SiteMeta(site), year) {
		<section class="home-profile" aria-labelledby="home-title">
			<div class="home-cover" aria-label="Singapore flag flypast">
				<img src="/static/images/home-banner.jpeg" alt="Helicopters carrying the Singapore flag during a flypast"/>
			</div>
			<div class="home-avatar" aria-hidden="true">
				<img src="/static/images/android-chrome-192x192.png" alt=""/>
			</div>
			<header class="home-intro">
				<h1 id="home-title">{ site.Name }</h1>
			</header>
		</section>
		<section class="post-list" aria-label="Blog posts">
			<h2 class="sr-only">Posts</h2>
			for _, post := range list {
				@PostCard(post)
			}
			if len(list) == 0 {
				<p>No posts yet.</p>
			}
		</section>
	}
}

templ PostCard(post posts.Post) {
	<article class={ postCardClass(post) }>
		<div class="post-card-body">
			<div class="post-card-meta">
				<time datetime={ post.Published.Format("2006-01-02") }>{ post.Published.Format("January 2, 2006") }</time>
				if post.Featured {
					<span class="featured-pill">Featured</span>
				}
			</div>
			<h2>
				<a href={ templ.URL(post.URLPath()) }>
					if post.Icon != "" {
						if IsImageIcon(post.Icon) {
							<img class="card-icon card-icon-image" src={ templ.SafeURL(post.Icon) } alt=""/>
						} else {
							<span class="card-icon" aria-hidden="true">{ post.Icon }</span>
						}
					}
					<span>{ post.Title }</span>
				</a>
			</h2>
			<p>{ post.Description }</p>
			if len(post.Tags) > 0 {
				<ul class="tags" aria-label="Tags">
					for _, tag := range post.Tags {
						<li>{ tag }</li>
					}
				</ul>
			}
		</div>
		if post.Cover != "" {
			<img class="post-card-cover" src={ templ.SafeURL(post.Cover) } alt=""/>
		}
	</article>
}

templ Search(site config.Site, year int, query string, results []posts.SearchResult) {
	@Layout(site, SearchMeta(site, query), year) {
		<section class="search-view">
			<header class="search-header">
				<h1>Search</h1>
				<form class="search-form" action="/search" method="get" role="search" data-search-form>
					<label class="sr-only" for="site-search">Search posts and pages</label>
					<input id="site-search" type="search" name="q" value={ query } placeholder="Search posts and pages" autocomplete="off" autofocus data-search-input/>
					<button class="search-submit" type="submit">
						@SearchIcon()
						<span>Search</span>
					</button>
				</form>
			</header>
			@SearchResults(query, results)
		</section>
	}
}

templ SearchResults(query string, results []posts.SearchResult) {
	<div id="search-results" class="search-results-region" aria-live="polite" aria-busy="false" data-search-results>
		if strings.TrimSpace(query) == "" {
			<p class="search-empty">Start typing to search posts and pages.</p>
		} else if len(results) == 0 {
			<p class="search-empty">No results for &ldquo;{ query }&rdquo;.</p>
		} else {
			<p class="search-count">{ len(results) } results for &ldquo;{ query }&rdquo;</p>
			<section class="search-results" aria-label="Search results">
				for _, result := range results {
					@SearchResult(result)
				}
			</section>
		}
	</div>
}

templ SearchResult(result posts.SearchResult) {
	<article class="search-result">
		<div class="search-result-meta">
			<span>{ result.Post.Kind }</span>
			<time datetime={ result.Post.Published.Format("2006-01-02") }>{ result.Post.Published.Format("January 2, 2006") }</time>
		</div>
		<h2>
			<a href={ templ.URL(result.Post.URLPath()) }>
				if result.Post.Icon != "" {
					if IsImageIcon(result.Post.Icon) {
						<img class="card-icon card-icon-image" src={ templ.SafeURL(result.Post.Icon) } alt=""/>
					} else {
						<span class="card-icon" aria-hidden="true">{ result.Post.Icon }</span>
					}
				}
				<span>{ result.Post.Title }</span>
			</a>
		</h2>
		<p>{ result.Excerpt }</p>
	</article>
}

templ PageIcon(post posts.Post) {
	if post.Icon != "" {
		if IsImageIcon(post.Icon) {
			<img class="page-icon page-icon-image" src={ templ.SafeURL(post.Icon) } alt=""/>
		} else {
			<div class="page-icon page-icon-text" aria-hidden="true">{ post.Icon }</div>
		}
	}
}

templ PostPage(site config.Site, year int, post posts.Post) {
	@Layout(site, PostMeta(site, post), year) {
		<article class="post">
			if post.Kind == "page" {
				<header class="post-header page-header">
					@PageIcon(post)
					<h1>{ post.Title }</h1>
				</header>
			} else {
				<header class="post-header">
					<div class="post-meta-row">
						<a class="back-link" href="/">&larr; All posts</a>
						<time datetime={ post.Published.Format("2006-01-02") }>{ post.Published.Format("January 2, 2006") }</time>
					</div>
					@PageIcon(post)
					<h1>{ post.Title }</h1>
					<p>{ post.Description }</p>
					if len(post.Tags) > 0 {
						<ul class="tags" aria-label="Tags">
							for _, tag := range post.Tags {
								<li>{ tag }</li>
							}
						</ul>
					}
				</header>
			}
			if post.Cover != "" {
				<img class="post-cover" src={ templ.SafeURL(post.Cover) } alt=""/>
			}
			<div class="prose">
				@templ.Raw(post.Body)
			</div>
		</article>
	}
}

templ NotFound(site config.Site, year int) {
	@Layout(site, NotFoundMeta(site), year) {
		<section class="empty-state">
			<p class="eyebrow">404</p>
			<h1>Page not found</h1>
			<p>The page you are looking for does not exist in this POC.</p>
			<img class="error-image" src="/static/images/404.png" alt="404 illustration"/>
			<a class="button-link" href="/">Return home</a>
		</section>
	}
}
