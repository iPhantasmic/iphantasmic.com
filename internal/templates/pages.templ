package templates

import (
	"iphantasmic.com/internal/config"
	"iphantasmic.com/internal/posts"
	"strings"
)

type Meta struct {
	Title       string
	Description string
	URL         string
	Canonical   string
	ActivePath  string
	Type        string
	Image       string
}

func SiteMeta(site config.Site) Meta {
	return Meta{
		Title:       site.Name,
		Description: site.Description,
		URL:         site.URL("/"),
		Canonical:   site.URL("/"),
		ActivePath:  "/",
		Type:        "website",
		Image:       site.URL("/static/images/home-banner.jpeg"),
	}
}

func PostMeta(site config.Site, post posts.Post) Meta {
	localURL := site.URL(post.URLPath())
	canonicalURL := strings.TrimSpace(post.Canonical)
	if canonicalURL == "" {
		canonicalURL = localURL
	}

	metaType := "article"
	if post.Kind == "page" {
		metaType = "website"
	}

	return Meta{
		Title:       post.Title,
		Description: post.Description,
		URL:         localURL,
		Canonical:   canonicalURL,
		ActivePath:  post.URLPath(),
		Type:        metaType,
		Image:       absoluteContentURL(site, post.Cover),
	}
}

func NotFoundMeta(site config.Site) Meta {
	return Meta{
		Title:       "Page not found",
		Description: "The requested page could not be found.",
		URL:         site.URL("/404"),
		Canonical:   site.URL("/404"),
		ActivePath:  "",
		Type:        "website",
		Image:       site.URL("/static/images/404.png"),
	}
}

func SearchMeta(site config.Site, query string) Meta {
	title := "Search"
	if strings.TrimSpace(query) != "" {
		title = "Search: " + strings.TrimSpace(query)
	}

	return Meta{
		Title:       title,
		Description: "Search posts and pages on " + site.Name + ".",
		URL:         site.URL("/search"),
		Canonical:   site.URL("/search"),
		ActivePath:  "/search",
		Type:        "website",
	}
}

func IsImageIcon(icon string) bool {
	icon = strings.TrimSpace(icon)
	return strings.HasPrefix(icon, "/") ||
		strings.HasPrefix(icon, "http://") ||
		strings.HasPrefix(icon, "https://")
}

func absoluteContentURL(site config.Site, value string) string {
	value = strings.TrimSpace(value)
	if value == "" {
		return ""
	}
	if strings.HasPrefix(value, "http://") || strings.HasPrefix(value, "https://") {
		return value
	}
	return site.URL(value)
}

func navLinkClass(activePath, linkPath string) string {
	if navLinkActive(activePath, linkPath) {
		return "nav-link active"
	}
	return "nav-link"
}

func navAriaCurrent(activePath, linkPath string) string {
	if navLinkActive(activePath, linkPath) {
		return "page"
	}
	return "false"
}

func navLinkActive(activePath, linkPath string) bool {
	if linkPath == "/" {
		return activePath == "/" || strings.HasPrefix(activePath, "/posts/")
	}
	return activePath == linkPath
}

func iconLinkClass(activePath, linkPath string) string {
	if navLinkActive(activePath, linkPath) {
		return "icon-button active"
	}
	return "icon-button"
}

func postCardClass(post posts.Post) string {
	if post.Featured {
		return "post-card post-card-featured"
	}
	return "post-card"
}

templ Layout(site config.Site, meta Meta, year int) {
	<!doctype html>
	<html lang="en">
		<head>
			<meta charset="utf-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1"/>
			<meta name="description" content={ meta.Description }/>
			<meta name="robots" content="index,follow"/>
			<title>{ meta.Title }</title>
			<link rel="canonical" href={ templ.URL(meta.Canonical) }/>
			<link rel="alternate" type="application/rss+xml" title={ site.Name } href="/feed.xml"/>
			<link rel="icon" href="/favicon.ico"/>
			<link rel="manifest" href="/static/manifest.json"/>
			<link rel="stylesheet" href="/assets/css/app.css"/>
			<meta property="og:site_name" content={ site.Name }/>
			<meta property="og:type" content={ meta.Type }/>
			<meta property="og:title" content={ meta.Title }/>
			<meta property="og:description" content={ meta.Description }/>
			<meta property="og:url" content={ meta.URL }/>
			if meta.Image != "" {
				<meta property="og:image" content={ meta.Image }/>
				<meta name="twitter:card" content="summary_large_image"/>
				<meta name="twitter:image" content={ meta.Image }/>
			} else {
				<meta name="twitter:card" content="summary"/>
			}
			<meta name="twitter:title" content={ meta.Title }/>
			<meta name="twitter:description" content={ meta.Description }/>
			<script src="/assets/js/theme.js" defer></script>
			<script src="/assets/js/search.js" defer></script>
		</head>
		<body>
			<header class="site-header">
				<a class="brand" href="/">
					<img class="brand-icon" src="/favicon.ico" alt=""/>
					<span>{ site.Name }</span>
				</a>
				<nav class="nav">
					<a class={ navLinkClass(meta.ActivePath, "/whoami.exe") } href="/whoami.exe" aria-current={ navAriaCurrent(meta.ActivePath, "/whoami.exe") }>whoami.exe</a>
					<a class={ iconLinkClass(meta.ActivePath, "/search") } href="/search" aria-label="Search" title="Search" aria-current={ navAriaCurrent(meta.ActivePath, "/search") }>
						@SearchIcon()
					</a>
					@ThemeToggle("nav-theme-toggle")
				</nav>
			</header>
			<main class="page-shell">
				{ children... }
			</main>
			<footer class="site-footer">
				<span>Copyright { year } { site.Author }</span>
				@ThemeToggle("footer-theme-toggle")
				<div class="footer-socials">
					<a class="social-link" href="https://github.com/iPhantasmic" aria-label="GitHub" rel="me noopener" target="_blank">
						@GitHubIcon()
					</a>
					<a class="social-link" href="https://www.linkedin.com/in/justinlamxikai" aria-label="LinkedIn" rel="me noopener" target="_blank">
						@LinkedInIcon()
					</a>
				</div>
			</footer>
		</body>
	</html>
}

templ SearchIcon() {
	<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
		<circle cx="11" cy="11" r="7"></circle>
		<path d="m20 20-3.5-3.5"></path>
	</svg>
}

templ ThemeToggle(extraClass string) {
	<button class={ "theme-toggle " + extraClass } type="button" data-theme-toggle aria-label="Toggle dark mode" title="Toggle dark mode">
		<span class="theme-icon theme-icon-light" aria-hidden="true">
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
				<circle cx="12" cy="12" r="4"></circle>
				<path d="M12 2v2"></path>
				<path d="M12 20v2"></path>
				<path d="m4.93 4.93 1.41 1.41"></path>
				<path d="m17.66 17.66 1.41 1.41"></path>
				<path d="M2 12h2"></path>
				<path d="M20 12h2"></path>
				<path d="m6.34 17.66-1.41 1.41"></path>
				<path d="m19.07 4.93-1.41 1.41"></path>
			</svg>
		</span>
		<span class="theme-icon theme-icon-dark" aria-hidden="true">
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
				<path d="M20.99 12.53A8.5 8.5 0 1 1 11.47 3.01 6.6 6.6 0 0 0 20.99 12.53Z"></path>
			</svg>
		</span>
	</button>
}

